aws_region      = "ap-south-1"           # AWS region to deploy resources (e.g., us-east-1, ap-south-1)
ami_id          = "ami-xxxxxxxxxxxxxxxxx" # AMI ID for your EC2 instance (e.g., ami-05d2d839d4f73aafb)
public_key_path = "./key.pem.pub"         # Path to your public SSH key file
my_ip_cidr      = "<your-public-ip>/32"      # Developer's workstation IP in CIDR notation for SSH access (e.g., 203.0.113.42/32)