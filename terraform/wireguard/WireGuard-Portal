## config/config.yaml

```yaml
core:
  admin_user: admin@wgportal.local
  admin_password: "your-admin-password"

web:
  external_url: "http://<wireguard-ec2-PUBLIC-ip>:8888"   # What the browser hits
  listening_address: ":8888"

auth:
  oidc:
    - provider_name: "keycloak"
      display_name: "Login with Keycloak"
      base_url: "http://<keycloak-ec2-PUBLIC-ip>/realms/<realm>"   # Must match Keycloak issuer exactly
      client_id: "wg-portal"
      client_secret: "<secret-from-keycloak-credentials-tab>"
      registration_enabled: true
      field_map:
        email: "email"
        firstname: "given_name"
        lastname: "family_name"
```

