# Ignore Terraform and OpenTofu state files
*.tfstate
*.tfstate.*

# Crash log files
crash.log

# Ignore variable files with sensitive data
*.tfvars
*.tfvars.json

# Ignore plan output
*.tfplan

# Ignore .terraform directory (modules/plugins)
.terraform/

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore backup files
*.backup

# Ignore local .terraformrc and .tofurc
.terraformrc
.tofurc

# Ignore .DS_Store (macOS)
.DS_Store

# Ignore log files
*.log

# .pem files (private keys)
*.pem

# notepad.md file for EC2 instance details
notepad.md